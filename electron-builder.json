{
  "appId": "com.yashpz.hello-electron",
  "productName": "Hello Electron",
  "files": ["dist-electron", "dist-react"],
  "extraResources": ["dist-electron/preload.js", "src/assets/**"],
  "icon": "./desktopIcon.png",
  "win": { "target": "nsis" },
  "nsis": {
    "oneClick": true,
    "allowToChangeInstallationDirectory": false
  },
  "mac": { "target": "dmg" },
  "linux": {
    "target": "AppImage",
    "category": "Utility"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "intellijenty",
      "repo": "hello-electron"
    }
  ]
}
