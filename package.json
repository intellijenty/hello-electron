{
  "name": "hello-electron",
  "author": {
    "name": "yashpz",
    "email": "ypzanzarukiya@gmail.com"
  },
  "private": true,
  "version": "1.0.1",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm-run-all -p dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "npm run transpile:electron && cross-env NODE_ENV=development electron .",
    "build": "tsc && vite build",
    "dist:win": "npm run transpile:electron && npm run build && electron-builder --win --x64",
    "dist:mac": "npm run transpile:electron && npm run build && electron-builder --mac --arm64",
    "dist:linux": "npm run transpile:electron && npm run build && electron-builder --linux --x64",
    "transpile:electron": "node scripts/build-electron.mjs",
    "build:renderer": "npm run build",
    "build:electron": "npm run transpile:electron",
    "publish": "npm run build:renderer && npm run build:electron && electron-builder --win --publish always",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "dependencies": {
    "@types/os-utils": "^0.0.4",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "os-utils": "^0.0.14",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^10.0.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
}
