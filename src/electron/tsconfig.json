{
  "compilerOptions": {
    "strict": true,
    // tell TypeScript to generate ESM syntax
    "target": "esnext",
    // tell TypeScript to generate ESM syntax as input
    "module": "nodenext",
    // define where the compiled files will be stored
    "outDir": "../../dist-electron",
    // ignore errors from dependencies
    "skipLibCheck": true,
    // include type definitions from the types
    "types": ["../../types"]
  }
}
